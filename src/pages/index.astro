          <p>Every package follows a clear checklist, estimated timing, and protection goal.</p>
        </div>
        <div class="pricing-grid">
          {plans.map(([name, price, time, features, note], i) => (
            <article class={`wow animate__animated animate__fadeInUp ${name === "Premium" ? "featured" : ""}`} data-wow-delay={`${0.15 * (i + 1)}s`}>
