      .booking-cta strong {
        color: #fff326;
      }

      .faq aside {
        padding-top: 10px;
      }

      .faq-lead {
        color: #ffffff;
        font-weight: 700;
        font-size: 1.05rem;
      }

      .faq-contact {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: #fff326;
        font-weight: 800;
      }

      .faq-list {
        display: grid;
        gap: 0;
      }

      .faq-item {
        border: 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.18);
        border-radius: 0;
        background: transparent;
        overflow: hidden;
        transition: border-color 200ms ease, background 200ms ease;
      }

      .faq-item:has(.faq-trigger[aria-expanded="true"]) {
        border-color: rgba(255, 243, 38, 0.55);
      }

      .faq-trigger {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding: 18px 0;
        background: transparent;
        border: 0;
        cursor: pointer;
        text-align: left;
        color: #ffffff;
        font-weight: 800;
        font-size: 1rem;
        font-family: inherit;
      }

      .faq-mark {
        flex: none;
        color: #fff326;
        transition: transform 240ms ease;
      }

      .faq-trigger[aria-expanded="true"] .faq-mark {
        transform: rotate(45deg);
      }

      .faq-panel {
        padding: 0 0 20px;
        animation: faqOpen 260ms ease;
      }

      .faq-panel p {
        margin: 0;
      }

      @keyframes faqOpen {
        from { opacity: 0; transform: translateY(-6px); }
        to { opacity: 1; transform: translateY(0); }
      }

      .blog {
        padding: 78px 0 92px;
      }

      .blog-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 24px;
      }

      .blog-grid article {
        overflow: hidden;
        transition: transform 200ms ease, border-color 200ms ease;
      }

      .blog-grid article:hover {
        transform: translateY(-6px);
        border-color: rgba(255, 243, 38, 0.45);
      }

      .blog-media {
        position: relative;
        overflow: hidden;
      }

      .blog-media img {
        width: 100%;
        aspect-ratio: 1.42;
        object-fit: cover;
        transition: transform 400ms ease;
      }

      .blog-grid article:hover .blog-media img {
        transform: scale(1.08);
      }

      .blog-body {
        padding: 28px 26px;
      }

      .blog-title-link {
        display: inline-block;
        color: #fff;
        transition: color 200ms ease;
      }

      .blog-title-link:hover h3 {
        color: #fff326;
      }

      .blog-body h3 {
        margin-bottom: 0;
        font-size: 1.18rem;
        line-height: 1.3;
      }

      .blog-meta {
        display: flex;
        align-items: center;
        gap: 22px;
        margin: 16px 0 14px;
        font-size: 0.95rem;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.82);
      }

      .blog-meta span {
        display: inline-flex;
        align-items: center;
        gap: 8px;
      }

      .blog-meta i {
        color: #fff326;
      }

      .site-footer {
        padding: 92px max(40px, calc((100vw - 1180px) / 2)) 28px;
        background: linear-gradient(to bottom, #1b1b1b, #111111);
        font-family: "Public Sans", Inter, Arial, sans-serif;
      }

      .footer-inner {
        display: grid;
        grid-template-columns: minmax(0, 1.05fr) minmax(220px, 0.95fr) minmax(280px, 1fr);
        gap: 72px;
        align-items: start;
      }

      .footer-brand img {
        width: auto;
        height: 34px;
        max-width: 320px;
        margin-bottom: 30px;
      }

      .footer-brand p,
      .footer-contact p,
      .footer-nav a,
      .footer-copy p {
        color: #b7b8b0;
        font-size: 1.08rem;
        line-height: 1.55;
      }

      .footer-brand p {
        max-width: 345px;
        margin-bottom: 28px;
        color: #f2f2ea;
        font-weight: 700;
      }

      .site-footer .footer-brand .outline-button {
        width: min(100%, 342px);
        min-height: 56px;
        padding: 0 32px;
        border-color: rgba(255, 255, 255, 0.92);
        border-radius: 999px;
        font-size: 1.03rem;
      }

      .site-footer .footer-nav {
        display: flex;
        align-items: flex-start;
        flex-direction: column;
        gap: 0;
      }

      .footer-heading {
        margin: 0 0 13px;
        font-family: "Libre Franklin", "Public Sans", Inter, Arial, sans-serif;
        font-size: 1.28rem;
        line-height: 1.2;
        font-weight: 800;
        color: #ffffff;
      }

      .site-footer .footer-nav hr,
      .site-footer .footer-contact hr {
        width: 100%;
        margin: 0 0 20px;
        border: 0;
        border-top: 2px solid rgba(255, 255, 255, 0.22);
      }

      .site-footer .footer-nav ul {
        display: grid;
        gap: 16px;
        margin: 0;
        padding: 0;
        list-style: none;
      }

      .site-footer .footer-nav a,
      .site-footer .footer-contact a {
        font-weight: 700;
        color: #b7b8b0;
      }

      .site-footer .footer-nav a.active,
      .site-footer .footer-nav a:hover,
      .site-footer .footer-contact a:hover {
        color: #fff326;
      }

      .footer-contact {
        display: grid;
        gap: 46px;
        font-style: normal;
      }

      .footer-contact p {
        margin-bottom: 0;
      }

      .footer-copy {
        padding-top: 68px;
        text-align: center;
      }

      .footer-copy p {
        margin: 0;
      }

      @media (max-width: 980px) {
        .site-header {
          grid-template-columns: 1fr auto;
          min-height: 88px;
          padding: 16px 22px;
          gap: 12px;
        }

        .brand img {
          width: min(300px, calc(100vw - 96px));
          max-height: 44px;
        }

        .nav-toggle {
          display: inline-grid;
          place-items: center;
          order: 2;
        }

        .site-header nav {
          order: 4;
          grid-column: 1 / -1;
          width: 100%;
          display: none;
          flex-direction: column;
          align-items: flex-start;
          gap: 6px;
          padding-top: 10px;
        }

        .site-header nav.open {
          display: flex;
        }

        .site-header nav .nav-link {
          font-size: 16px;
        }

        .outline-pill {
          display: none;
        }

        .nav-dropdown {
          width: 100%;
        }

        .dropdown-menu {
          position: static;
          display: none;
          min-width: 0;
          width: 100%;
          margin-top: 6px;
          box-shadow: none;
          background: rgba(255, 255, 255, 0.04);
        }

        .nav-dropdown:hover .dropdown-menu {
          display: none;
        }

        .dropdown-menu.open {
          display: flex;
        }

        h1 {
          font-size: 3.3rem;
        }

        h2 {
          font-size: 2.15rem;
        }

        .feature-band,
        .why,
        .review-grid,
        .pricing-grid,
        .blog-grid,
        .footer-inner,
        .grid-section {
          grid-template-columns: 1fr;
        }

        .feature-band {
          margin-top: -44px;
        }

        /* Services: collapse the floating-car arc into a stacked layout. */
        .service-stage {
          min-height: 0;
          display: grid;
          grid-template-columns: repeat(2, minmax(0, 1fr));
          gap: 40px 22px;
          padding-top: 40px;
        }

        .car-figure {
          position: static;
          transform: none;
          width: 100%;
          max-width: 420px;
          margin: 0 auto 8px;
          grid-column: 1 / -1;
          order: -1;
          filter: drop-shadow(0 24px 40px rgba(0, 0, 0, 0.6));
        }

        .service-card {
          position: static;
          width: auto;
        }

        .service-card.pos-1,
        .service-card.pos-2,
        .service-card.pos-3,
        .service-card.pos-4 {
          left: auto;
          right: auto;
          top: auto;
        }

        .pricing-grid article.featured {
          margin-top: 0;
          transform: none;
        }

        .pricing-heading {
          grid-template-columns: 1fr;
          gap: 18px;
        }

        .reviews {
          background-attachment: scroll;
        }

        /* fixed attachment is unreliable on mobile; fall back to scroll. */
        .booking-cta {
          background-attachment: scroll;
        }

        .why {
          padding: 32px;
        }
      }

      @media (max-width: 640px) {
        .site-header {
          position: sticky;
        }

        .brand img {
          width: min(260px, calc(100vw - 86px));
          max-height: 42px;
        }

        .site-header .outline-pill {
          display: none;
        }

        .hero {
          min-height: 560px;
        }

        h1 {
          font-size: 2.45rem;
        }

        h2 {
          font-size: 1.75rem;
        }

        .grid-section {
          gap: 30px;
          padding: 50px 0;
        }

        .reason-grid {
          grid-template-columns: 1fr;
        }

        .copy-stack {
          padding-left: 20px;
        }

        .feature-band article,
        .service-card,
        .review-grid article,
        .pricing-grid article {
          padding: 22px;
        }

        .quote-image figcaption {
          position: static;
          border-left: 0;
          border-top: 4px solid #fff326;
        }

        .site-footer {
          padding: 44px 22px;
        }

        .footer-inner {
          gap: 44px;
        }

        .footer-brand img {
          height: 32px;
        }

        .footer-heading {
          font-size: 1.18rem;
        }

        .footer-copy {
          padding-top: 44px;
          text-align: center;
        }
      }

      @media (min-width: 700px) and (max-width: 980px) {
        .site-footer .footer-inner {
          grid-template-columns: repeat(2, minmax(0, 1fr));
          gap: 48px 56px;
        }

        .site-footer .footer-brand {
          grid-column: 1 / -1;
        }
      }

      @media (max-width: 699px) {
        .site-footer .footer-brand {
          text-align: center;
        }

        .site-footer .footer-brand img {
          margin-left: auto;
          margin-right: auto;
        }

        .site-footer .footer-brand p,
        .site-footer .footer-brand .outline-button {
          margin-left: auto;
          margin-right: auto;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .wow {
          animation: none !important;
          visibility: visible !important;
        }
        .hero-bg {
          animation: none;
        }
        .booking-cta {
          background-attachment: scroll;
        }
      }
    </style>
  </body>
</html>
