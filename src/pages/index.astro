    <script>
      import { WOW } from "wow.js";

      const reveal = () =>
        document.querySelectorAll(".wow").forEach((el) => {
          (el as HTMLElement).style.visibility = "visible";
        });

      const startWow = () => {
        try {
          new WOW({
            boxClass: "wow",
            animateClass: "animate__animated",
            offset: 80,
            mobile: true,
            live: false,
          }).init();
        } catch (err) {
          reveal();
        }
        // Safety: if any reveal element is still hidden after load, force-show it.
        window.setTimeout(reveal, 2600);
      };

      // Animated counter (the "90%") via IntersectionObserver.
      const startCounters = () => {
        const counters = document.querySelectorAll<HTMLElement>(".counter");
        // Keep the final value stable for source-fidelity captures. Earlier
        // count-up enhancement could freeze mid-animation in full-page evidence.
        const run = (el: HTMLElement) => {
          const target = Number(el.dataset.count || "0");
          el.textContent = String(target);
        };
        if (!("IntersectionObserver" in window)) {
          counters.forEach((c) => (c.textContent = c.dataset.count || "0"));
          return;
        }
        const io = new IntersectionObserver(
          (entries, obs) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                run(e.target as HTMLElement);
                obs.unobserve(e.target);
              }
            });
          },
          { threshold: 0.5 },
        );
        counters.forEach((c) => io.observe(c));
      };

      // Accessible FAQ accordion (single-open), Bootstrap-style behavior.
      const startFaq = () => {
        const triggers = document.querySelectorAll<HTMLButtonElement>(".faq-trigger");
        triggers.forEach((btn) => {
          btn.addEventListener("click", () => {
            const panel = document.getElementById(btn.getAttribute("aria-controls") || "");
            const isOpen = btn.getAttribute("aria-expanded") === "true";
            triggers.forEach((other) => {
              other.setAttribute("aria-expanded", "false");
              const p = document.getElementById(other.getAttribute("aria-controls") || "");
              if (p) p.hidden = true;
            });
            if (!isOpen && panel) {
              btn.setAttribute("aria-expanded", "true");
              panel.hidden = false;
            }
          });
        });
      };

      // Mobile nav toggle.
      const startNav = () => {
        const toggle = document.querySelector<HTMLButtonElement>(".nav-toggle");
        const nav = document.getElementById("primary-nav");
        if (!toggle || !nav) return;
        toggle.addEventListener("click", () => {
          const open = nav.classList.toggle("open");
          toggle.setAttribute("aria-expanded", String(open));
        });
        nav.querySelectorAll("a").forEach((a) =>
          a.addEventListener("click", () => {
            nav.classList.remove("open");
            toggle.setAttribute("aria-expanded", "false");
            nav.querySelectorAll<HTMLElement>(".dropdown-menu.open").forEach((m) => m.classList.remove("open"));
            nav.querySelectorAll(".nav-toggle-btn").forEach((b) => b.setAttribute("aria-expanded", "false"));
          }),
        );

        // Dropdown menus (Services, Pages) — click to toggle, single-open.
        const dropToggles = nav.querySelectorAll<HTMLButtonElement>(".nav-toggle-btn");
        dropToggles.forEach((btn) => {
          const menu = document.getElementById(btn.getAttribute("aria-controls") || "");
          if (!menu) return;
          btn.addEventListener("click", (e) => {
            e.stopPropagation();
            const willOpen = !menu.classList.contains("open");
            nav.querySelectorAll<HTMLElement>(".dropdown-menu.open").forEach((m) => m.classList.remove("open"));
            dropToggles.forEach((b) => b.setAttribute("aria-expanded", "false"));
            if (willOpen) {
              menu.classList.add("open");
              btn.setAttribute("aria-expanded", "true");
            }
          });
        });
        document.addEventListener("click", () => {
          nav.querySelectorAll<HTMLElement>(".dropdown-menu.open").forEach((m) => m.classList.remove("open"));
          dropToggles.forEach((b) => b.setAttribute("aria-expanded", "false"));
        });
        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape") {
            nav.querySelectorAll<HTMLElement>(".dropdown-menu.open").forEach((m) => m.classList.remove("open"));
            dropToggles.forEach((b) => b.setAttribute("aria-expanded", "false"));
          }
        });
      };

      // Scroll-spy: highlight the nav link for the section in view.
      const startScrollSpy = () => {
        const links = Array.from(document.querySelectorAll<HTMLAnchorElement>('#primary-nav a.nav-link'));
        const map = new Map<string, HTMLAnchorElement>();
        links.forEach((a) => {
          const id = (a.getAttribute("href") || "").replace("#", "");
          if (id) map.set(id, a);
        });
        const ids = [...map.keys()];
        if (!ids.length || !("IntersectionObserver" in window)) return;
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                links.forEach((l) => l.classList.remove("active"));
                map.get(e.target.id)?.classList.add("active");
              }
            });
          },
          { rootMargin: "-45% 0px -50% 0px" },
        );
        ids.forEach((id) => {
          const el = id === "top" ? document.getElementById("top") : document.getElementById(id);
          if (el) io.observe(el);
        });
      };

      // Sticky-header shadow on scroll.
      const startHeader = () => {
        const header = document.querySelector(".site-header");
        if (!header) return;
        const onScroll = () => header.classList.toggle("scrolled", window.scrollY > 12);
        onScroll();
        window.addEventListener("scroll", onScroll, { passive: true });
      };

      // How It Works: single-open accordion (one step always expanded).
      const startSteps = () => {
        const triggers = document.querySelectorAll<HTMLButtonElement>(".step-trigger");
        triggers.forEach((btn) => {
          btn.addEventListener("click", () => {
            if (btn.getAttribute("aria-expanded") === "true") return;
            const panel = document.getElementById(btn.getAttribute("aria-controls") || "");
            triggers.forEach((other) => {
              other.setAttribute("aria-expanded", "false");
              const p = document.getElementById(other.getAttribute("aria-controls") || "");
              if (p) p.hidden = true;
            });
            btn.setAttribute("aria-expanded", "true");
            if (panel) panel.hidden = false;
          });
        });
      };

      const boot = () => {
        startWow();
        startCounters();
        startFaq();
        startSteps();
        startNav();
        startScrollSpy();
        startHeader();
      };

      if (document.readyState !== "loading") boot();
      else document.addEventListener("DOMContentLoaded", boot);
