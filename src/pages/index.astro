          <h2>Expert tips and insights for car enthusiasts</h2>
        </div>
        <div class="blog-grid">
          {posts.map(([title, image, category, copy], i) => (
            <article class="wow animate__animated animate__fadeInUp" data-wow-delay={`${0.15 * (i + 1)}s`}>
