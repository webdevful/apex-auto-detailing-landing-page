---
import "@fortawesome/fontawesome-free/css/all.min.css";
import "animate.css/animate.min.css";

const mediaBase = "/images/apex-auto-detailing";

const features = [
  ["fa-gem", "Advanced Detailing Technology", "Professional tools restore your car's original beauty and leave it fresh, clean, and protected."],
  ["fa-leaf", "Eco-Friendly Products", "Water-smart methods and safe products support a cleaner finish with a lighter footprint."],
  ["fa-shield-halved", "Satisfaction Guarantee", "Every vehicle gets a final walkaround before the keys return to your hand."],
];

const services = [
  ["fa-car-side", "Exterior Detailing", "Hand wash, clay treatment, polish, wax, and sealant for a deep gloss finish."],
  ["fa-couch", "Interior Detailing", "Steam-cleaned seats, carpets, trim, vents, dashboard, glass, and hard-to-reach surfaces."],
  ["fa-wand-magic-sparkles", "Paint Correction", "Swirl reduction, oxidation removal, and finishing polish for cleaner reflections."],
  ["fa-shield-halved", "Ceramic Coating", "Long-lasting protection against sun, dirt, rain, and road film with a high-gloss shield."],
];

const reasons = [
  ["01", "fa-user-tie", "Professional Expertise", "Trained detailers use careful techniques for modern paint, trim, leather, and wheels."],
  ["02", "fa-spray-can-sparkles", "Premium Quality Products", "Biodegradable soaps, pH-balanced cleaners, and pro-grade finishing products."],
  ["03", "fa-magnifying-glass", "Attention To Detail", "Edges, seams, vents, wheel barrels, glass, and high-touch interior points all get checked."],
  ["04", "fa-thumbs-up", "Satisfaction Guaranteed", "A final walkaround makes sure the finish meets the promised package standard."],
];

const steps = [
  ["01. Book Your Appointment", "Choose the package, tell us where the car is parked, and pick a time that fits your day. You can book online, call us, or visit our location and we'll confirm the details."],
  ["02. We Detail Your Car", "Our crew arrives prepared with water-smart tools, safe products, and a finish checklist, treating every surface inside and out with care."],
  ["03. Enjoy the Shine", "Drive away with a refreshed vehicle, protected surfaces, and that clean-car feeling restored, ready to turn heads wherever you go."],
];

const reviews = [
  ["Raul Axios", "Auto Dealer", "Absolutely incredible service. My car looked brand new inside and out, and the attention to detail was obvious in every surface.", "avatar-1.jpg"],
  ["Ubeid Una", "Car Owner", "I've used many detailing services before, but this one exceeded my expectations. Professional, friendly, and an amazing job on my vehicle.", "avatar-2.jpg"],
  ["Taki Wanabe", "Vintage Car Owner", "I was blown away by the transformation. From the deep interior clean to the protected exterior, my car looks better than ever.", "avatar-3.jpg"],
  ["Hafsha Jasmine", "Auto Dealer", "The team took extra care detailing my car and the results are nothing short of amazing. I'll definitely return for regular maintenance.", "avatar-5.jpg"],
  ["Akio Mirfaq", "Car Owner", "The best detailing service I've ever had. My car looks immaculate and it feels like I'm driving a completely different vehicle.", "avatar-4.jpg"],
  ["Olivia Seamo", "Car Collector", "From the moment I walked in I knew I was in good hands. Knowledgeable, friendly, and an incredible job. Spotless inside and out.", "avatar-6.jpg"],
];

const plans = [
  ["Basic", "$299.99", "Estimated time: 1.5-2 hours", ["Exterior hand wash", "Interior vacuum and wipe", "Windows cleaned", "Tire dressing"], "Regular maintenance and freshening up."],
  ["Premium", "$499.99", "Estimated time: 2-3 hours", ["Everything in Basic", "Deep interior cleaning", "Clay bar treatment", "Engine bay cleaning"], "A deep clean inside and out with added protection."],
  ["Ultimate", "$999.99", "Estimated time: 4-7 hours", ["Everything in Premium", "Paint correction", "Ceramic coating", "Leather conditioning"], "Maximum protection and showroom-level restoration."],
];

const faqs = [
  ["What is car detailing?", "Car detailing is a careful cleaning, restoration, and protection process for the interior and exterior of your vehicle."],
  ["How often should I get my car detailed?", "Most vehicles benefit from a maintenance detail every 3 to 6 months, depending on use, parking, and weather."],
  ["Do you use eco-friendly products?", "Yes. Apex Auto Detailing uses water-smart methods and biodegradable products whenever the vehicle surface allows it."],
  ["How long does a detailing service take?", "A basic detail takes about 1.5 to 2 hours, while a full ultimate detail can take 4 to 7 hours depending on the vehicle."],
  ["Do you offer mobile detailing services?", "Yes. We bring the tools and products to your home or workplace so the service fits around your day."],
];

const posts = [
  ["The Ultimate Guide To Engine Cleaning", "engine.jpg", "Cleaning", "H. Jasmine", "How to keep the engine bay looking cared for without risking sensitive parts."],
  ["Essential Car Maintenance Tips for Longevity", "polish.jpg", "Maintenance", "H. Jasmine", "Small detailing habits that protect trim, paint, glass, and interior surfaces."],
  ["Protecting Your Car Paint from Sun Damage", "paint.jpg", "Protection", "H. Jasmine", "Why wax, sealants, and ceramic coatings matter for cars parked outdoors."],
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Apex Auto Detailing | Professional Mobile Car Detailing</title>
    <meta
      name="description"
      content="Apex Auto Detailing is a one-page car detailing landing page for mobile wash, polish, interior, and ceramic coating services."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Libre+Franklin:wght@600;700;800;900&family=Public+Sans:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
