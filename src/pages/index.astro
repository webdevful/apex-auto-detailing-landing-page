        <img src="/assets/img/logo/apex-auto-detailing/logo_white.png" alt="Apex Auto Detailing" />
        <p>Premium mobile car detailing services that bring out the best in your vehicle.</p>
        <a class="outline-button" href="mailto:hello@apexautodetailing.example">Contact Us <i class="fa-solid fa-arrow-right" aria-hidden="true"></i></a>
      </div>
      <nav aria-label="Footer navigation">
        <h2>Navigation</h2>
        <a href="#top">Homepage</a>
        <a href="#services">Services</a>
        <a href="#pricing">Pricing</a>
        <a href="#faq">FAQs</a>
      </nav>
      <address>
        <h2>Visit Our Office</h2>
        <p><i class="fa-solid fa-location-dot" aria-hidden="true"></i> 123 Serenity Lane, Blissfield, CA 90210</p>
        <h2>Contact Info</h2>
        <p><i class="fa-solid fa-phone" aria-hidden="true"></i> <a href="tel:+15551234567">(555) 123-4567</a></p>
        <p><i class="fa-solid fa-envelope" aria-hidden="true"></i> <a href="mailto:hello@apexautodetailing.example">hello@apexautodetailing.example</a></p>
      </address>
    </footer>

    <script>
      import { WOW } from "wow.js";

      const reveal = () =>
        document.querySelectorAll(".wow").forEach((el) => {
          (el as HTMLElement).style.visibility = "visible";
        });

      const startWow = () => {
        try {
          new WOW({
            boxClass: "wow",
            animateClass: "animate__animated",
            offset: 80,
            mobile: true,
            live: false,
          }).init();
        } catch (err) {
          reveal();
        }
        // Safety: if any reveal element is still hidden after load, force-show it.
        window.setTimeout(reveal, 2600);
      };

      // Animated counter (the "90%") via IntersectionObserver.
      const startCounters = () => {
        const counters = document.querySelectorAll<HTMLElement>(".counter");
        const run = (el: HTMLElement) => {
          const target = Number(el.dataset.count || "0");
          const duration = 1500;
          const start = performance.now();
          const tick = (now: number) => {
            const p = Math.min((now - start) / duration, 1);
            el.textContent = String(Math.round(p * target));
            if (p < 1) requestAnimationFrame(tick);
          };
          requestAnimationFrame(tick);
        };
        if (!("IntersectionObserver" in window)) {
          counters.forEach((c) => (c.textContent = c.dataset.count || "0"));
          return;
        }
        const io = new IntersectionObserver(
          (entries, obs) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                run(e.target as HTMLElement);
                obs.unobserve(e.target);
              }
            });
          },
          { threshold: 0.5 },
        );
        counters.forEach((c) => io.observe(c));
      };

      // Accessible FAQ accordion (single-open), Bootstrap-style behavior.
      const startFaq = () => {
        const triggers = document.querySelectorAll<HTMLButtonElement>(".faq-trigger");
        triggers.forEach((btn) => {
          btn.addEventListener("click", () => {
            const panel = document.getElementById(btn.getAttribute("aria-controls") || "");
            const isOpen = btn.getAttribute("aria-expanded") === "true";
            triggers.forEach((other) => {
              other.setAttribute("aria-expanded", "false");
              const p = document.getElementById(other.getAttribute("aria-controls") || "");
              if (p) p.hidden = true;
            });
            if (!isOpen && panel) {
              btn.setAttribute("aria-expanded", "true");
              panel.hidden = false;
            }
          });
        });
      };

      // Mobile nav toggle.
      const startNav = () => {
        const toggle = document.querySelector<HTMLButtonElement>(".nav-toggle");
        const nav = document.getElementById("primary-nav");
        if (!toggle || !nav) return;
        toggle.addEventListener("click", () => {
          const open = nav.classList.toggle("open");
          toggle.setAttribute("aria-expanded", String(open));
        });
        nav.querySelectorAll("a").forEach((a) =>
          a.addEventListener("click", () => {
            nav.classList.remove("open");
            toggle.setAttribute("aria-expanded", "false");
          }),
        );
      };

      // Sticky-header shadow on scroll.
      const startHeader = () => {
        const header = document.querySelector(".site-header");
        if (!header) return;
        const onScroll = () => header.classList.toggle("scrolled", window.scrollY > 12);
        onScroll();
        window.addEventListener("scroll", onScroll, { passive: true });
      };

      const boot = () => {
        startWow();
        startCounters();
        startFaq();
        startNav();
        startHeader();
      };

      if (document.readyState !== "loading") boot();
      else document.addEventListener("DOMContentLoaded", boot);
    </script>

    <style>
      :global(*) {
        box-sizing: border-box;
      }

      :global(html) {
        scroll-behavior: smooth;
        background: #0b0c0b;
      }

      :global(body) {
        margin: 0;
        font-family: "Public Sans", Inter, Arial, sans-serif;
        color: #f7f7ef;
        background: #0b0c0b;
      }

      :global(a) {
        color: inherit;
        text-decoration: none;
      }

      :global(img) {
        display: block;
        max-width: 100%;
      }

      /* Reveal elements stay visible by default; wow.js hides+reveals when JS runs. */
      .wow {
        visibility: visible;
      }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 20;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
        min-height: 92px;
        padding: 14px 56px;
        background: rgba(7, 8, 7, 0.92);
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        backdrop-filter: blur(12px);
        transition: background 220ms ease, box-shadow 220ms ease;
      }

      .site-header.scrolled {
        background: rgba(7, 8, 7, 0.98);
        box-shadow: 0 12px 30px rgba(0, 0, 0, 0.35);
      }

      .brand {
        display: inline-flex;
        align-items: center;
      }

      .brand img {
        width: auto;
        height: 56px;
      }

      .nav-toggle {
        display: none;
        background: transparent;
        border: 0;
        color: #fff326;
        font-size: 1.4rem;
        cursor: pointer;
      }

      .site-header nav,
      footer nav {
        display: flex;
        align-items: center;
        gap: 24px;
      }

      .site-header nav a {
        position: relative;
        font-size: 0.88rem;
        font-weight: 700;
        padding: 4px 0;
      }

      .site-header nav a::after {
        content: "";
        position: absolute;
        left: 0;
        bottom: -2px;
        width: 0;
        height: 2px;
        background: #fff326;
        transition: width 200ms ease;
      }

      .site-header nav a:hover::after,
      .site-header nav a:focus-visible::after {
        width: 100%;
      }

      .pill-button,
      .outline-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 9px;
        min-height: 44px;
        padding: 0 22px;
        border-radius: 999px;
        font-weight: 800;
        font-size: 0.9rem;
        transition: transform 180ms ease, background 180ms ease, color 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
      }

      .pill-button {
        background: #fff326;
        color: #12130f;
        border: 1px solid #fff326;
      }

      .pill-button:hover,
      .pill-button:focus-visible {
        transform: translateY(-2px) scale(1.03);
        background: #ffffff;
        border-color: #ffffff;
        box-shadow: 0 12px 26px rgba(255, 243, 38, 0.22);
      }

      .pill-button.small {
        min-height: 40px;
        padding: 0 18px;
        font-size: 0.78rem;
      }

      .outline-button {
        border: 1px solid rgba(255, 255, 255, 0.42);
        color: #ffffff;
      }

      .outline-button:hover {
        border-color: #fff326;
        color: #fff326;
      }

      .section-shell,
      .grid-section {
        width: min(1180px, calc(100% - 40px));
        margin: 0 auto;
      }

      .hero {
        position: relative;
        min-height: 640px;
        display: grid;
        align-items: center;
        overflow: hidden;
      }

      .hero-bg {
        position: absolute;
        inset: 0;
        background:
          linear-gradient(90deg, rgba(5, 6, 5, 0.98) 0%, rgba(5, 6, 5, 0.82) 46%, rgba(5, 6, 5, 0.48) 100%),
          url("/images/apex-auto-detailing/hero-interior.jpg") center / cover no-repeat;
        opacity: 0.84;
      }

      .hero-content {
        position: relative;
        max-width: 650px;
        padding-top: 40px;
      }

      .eyebrow {
        display: inline-block;
        margin: 0 0 12px;
        color: #fff326;
        font-weight: 900;
        text-transform: uppercase;
        font-size: 0.78rem;
        letter-spacing: 0.06em;
      }

      h1,
      h2,
      h3,
      h4,
      p {
        margin-top: 0;
        letter-spacing: 0;
      }

      h1 {
        margin-bottom: 30px;
        font-size: 4.5rem;
        line-height: 0.94;
        max-width: 760px;
      }

      h2 {
        font-size: 2.7rem;
        line-height: 1.04;
        margin-bottom: 18px;
      }

      h3 {
        font-size: 1.25rem;
        line-height: 1.2;
      }

      p {
        color: #cfd0c6;
        line-height: 1.72;
        font-size: 1rem;
      }

      .feature-band {
        width: min(960px, calc(100% - 40px));
        margin: -76px auto 90px;
        position: relative;
        z-index: 4;
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 14px;
      }

      .feature-band article,
      .service-card,
      .why,
      .review-grid article,
      .pricing-grid article,
      .blog-grid article {
        background: #181a18;
        border: 1px solid rgba(255, 255, 255, 0.07);
        border-radius: 8px;
      }

      .feature-band article {
        padding: 26px 24px;
        transition: transform 200ms ease, border-color 200ms ease;
      }

      .feature-band article:hover {
        transform: translateY(-6px);
        border-color: rgba(255, 243, 38, 0.5);
      }

      .feature-icon,
      .service-icon,
      .reason-icon,
      .step-icon {
        display: inline-grid;
        place-items: center;
        color: #fff326;
      }

      .feature-icon {
        width: 48px;
        height: 48px;
        margin-bottom: 14px;
        border-radius: 12px;
        background: rgba(255, 243, 38, 0.12);
        font-size: 1.2rem;
      }

      .feature-band h2 {
        font-size: 1.05rem;
        margin: 4px 0 8px;
      }

      .feature-band p,
      .service-card p,
      .pricing-grid p,
      .blog-grid p {
        font-size: 0.9rem;
      }

      .grid-section {
        display: grid;
        grid-template-columns: 0.85fr 1.15fr;
        gap: 70px;
        align-items: start;
        padding: 72px 0;
      }

      .about h2 strong,
      .why h2,
      .faq h2 {
        color: #ffffff;
      }

      .copy-stack {
        border-left: 1px solid rgba(255, 243, 38, 0.38);
        padding-left: 34px;
      }

      .section-heading {
        max-width: 780px;
        margin: 0 auto 42px;
      }

      .center {
        text-align: center;
      }

      .services {
        padding: 44px 0 90px;
      }

      .service-stage {
        display: grid;
        grid-template-columns: 1fr 1.4fr 1fr;
        align-items: center;
        gap: 24px;
      }

      .service-grid {
        display: grid;
        gap: 24px;
      }

      .service-grid.right {
        margin-top: 70px;
      }

      .service-card {
        position: relative;
        min-height: 230px;
        padding: 34px 24px 24px;
        transition: transform 200ms ease, border-color 200ms ease, background 200ms ease;
      }

      .service-card:hover,
      .service-card:focus-within {
        transform: translateY(-6px);
        border-color: rgba(255, 243, 38, 0.56);
        background: #1c1f1c;
      }

      .service-icon {
        width: 52px;
        height: 52px;
        margin-bottom: 14px;
        border-radius: 50%;
        background: #fff326;
        color: #0e0f0c;
        font-size: 1.25rem;
        transition: transform 220ms ease;
      }

      .service-card:hover .service-icon {
        transform: rotate(-8deg) scale(1.08);
      }

      .service-card a {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin-top: 14px;
        font-weight: 800;
        color: #ffffff;
        font-size: 0.9rem;
      }

      .service-card a:hover {
        color: #fff326;
      }

      .car-figure {
        margin: 0;
        min-height: 380px;
        display: grid;
        place-items: center;
        border-radius: 10px;
        background:
          radial-gradient(circle at 50% 60%, rgba(255, 243, 38, 0.2), transparent 42%),
          linear-gradient(180deg, #10110f, #090a09);
      }

      .car-figure img {
        width: 100%;
        border-radius: 8px;
        mix-blend-mode: screen;
      }

      .why {
        display: grid;
        grid-template-columns: 0.45fr 1fr;
        gap: 54px;
        padding: 56px;
        margin-top: 42px;
        margin-bottom: 50px;
      }

      .score-card strong {
        display: block;
        color: #fff326;
        font-size: 4.5rem;
        line-height: 1;
        margin: 34px 0 12px;
      }

      .why-main > p {
        max-width: 720px;
      }

      .reason-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 28px;
        margin-top: 34px;
      }

      .reason-grid article {
        position: relative;
      }

      .reason-icon {
        width: 44px;
        height: 44px;
        margin-bottom: 12px;
        border-radius: 10px;
        background: rgba(255, 243, 38, 0.12);
        font-size: 1.1rem;
      }

      .reason-number {
        position: absolute;
        top: 0;
        right: 0;
        color: rgba(255, 243, 38, 0.5);
        font-weight: 900;
        font-size: 0.95rem;
      }

      .reason-grid h3 {
        margin: 8px 0;
      }

      .process {
        align-items: center;
      }

      .steps {
        margin-top: 32px;
        border-top: 1px solid rgba(255, 255, 255, 0.16);
      }

      .steps article {
        display: flex;
        align-items: flex-start;
        gap: 18px;
        padding: 18px 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.16);
      }

      .step-icon {
        flex: none;
        width: 46px;
        height: 46px;
        border-radius: 50%;
        background: rgba(255, 243, 38, 0.12);
        font-size: 1.1rem;
      }

      .steps h3 {
        margin-bottom: 6px;
      }

      .quote-image {
        margin: 0;
        position: relative;
        border-radius: 10px;
        overflow: hidden;
      }

      .quote-image img {
        width: 100%;
        min-height: 420px;
        object-fit: cover;
        transition: transform 600ms ease;
      }

      .quote-image:hover img {
        transform: scale(1.05);
      }

      .quote-image figcaption {
        position: absolute;
        right: 28px;
        bottom: 28px;
        max-width: 330px;
        padding: 22px;
        background: rgba(10, 10, 9, 0.84);
        border-left: 4px solid #fff326;
        color: #ffffff;
        font-weight: 800;
        line-height: 1.4;
      }

      .reviews {
        padding: 86px 0;
        background:
          linear-gradient(180deg, rgba(9, 10, 9, 0.8), #0b0c0b),
          url("/images/apex-auto-detailing/hero-interior.jpg") center / cover no-repeat fixed;
        max-width: none;
        width: 100%;
      }

      .reviews .section-heading,
      .review-grid {
        width: min(1180px, calc(100% - 40px));
        margin-left: auto;
        margin-right: auto;
      }

      .review-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 22px;
      }

      .review-grid article {
        position: relative;
        padding: 30px 28px;
        transition: transform 200ms ease, border-color 200ms ease;
      }

      .review-grid article:hover {
        transform: translateY(-6px);
        border-color: rgba(255, 243, 38, 0.45);
      }

      .quote-mark {
        color: rgba(255, 243, 38, 0.5);
        font-size: 1.4rem;
      }

      .stars {
        display: flex;
        gap: 4px;
        margin: 10px 0 14px;
        color: #fff326;
        font-size: 0.85rem;
      }

      .person {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-top: 24px;
      }

      .person img {
        width: 54px;
        height: 54px;
        border-radius: 50%;
        object-fit: cover;
      }

      .person span {
        display: grid;
        gap: 2px;
        color: #cfd0c6;
        font-size: 0.86rem;
      }

      .person strong {
        color: #ffffff;
      }

      .pricing {
        padding: 80px 0;
      }

      .pricing-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 22px;
        align-items: start;
      }

      .pricing-grid article {
        position: relative;
        padding: 32px 30px;
        display: flex;
        flex-direction: column;
        gap: 14px;
        transition: transform 200ms ease, border-color 200ms ease;
      }

      .pricing-grid article:hover {
        transform: translateY(-8px);
        border-color: rgba(255, 243, 38, 0.5);
      }

      .pricing-grid article.featured {
        border-color: rgba(255, 243, 38, 0.58);
        transform: translateY(-12px);
        background: #1b1d18;
      }

      .pricing-grid article.featured:hover {
        transform: translateY(-18px);
      }

      .badge {
        position: absolute;
        top: -12px;
        right: 24px;
        padding: 5px 14px;
        border-radius: 999px;
        background: #fff326;
        color: #12130f;
        font-size: 0.72rem;
        font-weight: 900;
        text-transform: uppercase;
      }

      .plan-time {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        color: #a9aaa0;
        font-size: 0.82rem;
      }

      .pricing-grid strong {
        color: #fff326;
        font-size: 2.35rem;
        line-height: 1;
      }

      .pricing-grid ul {
        display: grid;
        gap: 10px;
        margin: 0;
        padding: 0;
        list-style: none;
      }

      .pricing-grid li {
        display: flex;
        align-items: center;
        gap: 10px;
        color: #d6d7ce;
        font-size: 0.92rem;
      }

      .pricing-grid li i {
        color: #fff326;
        font-size: 0.8rem;
      }

      .booking-cta {
        width: min(900px, calc(100% - 40px));
        margin: 40px auto 80px;
        padding: 70px 28px;
        text-align: center;
        border-radius: 14px;
        background:
          radial-gradient(circle at 50% 0%, rgba(255, 243, 38, 0.18), transparent 52%),
          #141612;
        border: 1px solid rgba(255, 243, 38, 0.18);
      }

      .booking-cta h2 {
        max-width: 640px;
        margin-left: auto;
        margin-right: auto;
      }

      .booking-cta strong {
        color: #fff326;
      }

      .faq aside {
        padding-top: 10px;
      }

      .faq-lead {
        color: #ffffff;
        font-weight: 700;
        font-size: 1.05rem;
      }

      .faq-contact {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: #fff326;
        font-weight: 800;
      }

      .faq-list {
        display: grid;
        gap: 12px;
      }

      .faq-item {
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 8px;
        background: #161816;
        overflow: hidden;
        transition: border-color 200ms ease;
      }

      .faq-item:has(.faq-trigger[aria-expanded="true"]) {
        border-color: rgba(255, 243, 38, 0.5);
      }

      .faq-trigger {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding: 18px 22px;
        background: transparent;
        border: 0;
        cursor: pointer;
        text-align: left;
        color: #ffffff;
        font-weight: 800;
        font-size: 1rem;
        font-family: inherit;
      }

      .faq-mark {
        flex: none;
        color: #fff326;
        transition: transform 240ms ease;
      }

      .faq-trigger[aria-expanded="true"] .faq-mark {
        transform: rotate(45deg);
      }

      .faq-panel {
        padding: 0 22px 20px;
        animation: faqOpen 260ms ease;
      }

      .faq-panel p {
        margin: 0;
      }

      @keyframes faqOpen {
        from { opacity: 0; transform: translateY(-6px); }
        to { opacity: 1; transform: translateY(0); }
      }

      .blog {
        padding: 78px 0 92px;
      }

      .blog-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 22px;
      }

      .blog-grid article {
        overflow: hidden;
        transition: transform 200ms ease, border-color 200ms ease;
      }

      .blog-grid article:hover {
        transform: translateY(-6px);
        border-color: rgba(255, 243, 38, 0.45);
      }

      .blog-media {
        position: relative;
        overflow: hidden;
      }

      .blog-media img {
        width: 100%;
        aspect-ratio: 1.42;
        object-fit: cover;
        transition: transform 400ms ease;
      }

      .blog-grid article:hover .blog-media img {
        transform: scale(1.08);
      }

      .blog-tag {
        position: absolute;
        left: 16px;
        top: 16px;
        padding: 5px 12px;
        border-radius: 999px;
        background: #fff326;
        color: #12130f;
        font-size: 0.72rem;
        font-weight: 900;
        text-transform: uppercase;
      }

      .blog-body {
        padding: 22px;
      }

      .blog-body h3 {
        margin-bottom: 10px;
      }

      .blog-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin-top: 8px;
        font-weight: 800;
        font-size: 0.88rem;
        color: #fff326;
      }

      footer {
        display: grid;
        grid-template-columns: 1.25fr 0.8fr 1fr;
        gap: 54px;
        padding: 64px max(40px, calc((100vw - 1180px) / 2));
        background: #151715;
        border-top: 1px solid rgba(255, 255, 255, 0.08);
      }

      footer img {
        width: auto;
        height: 54px;
        margin-bottom: 18px;
      }

      footer nav {
        align-items: flex-start;
        flex-direction: column;
        gap: 12px;
      }

      footer nav a:hover {
        color: #fff326;
      }

      footer h2 {
        font-size: 1.1rem;
        margin-bottom: 12px;
      }

      address {
        font-style: normal;
      }

      address i {
        color: #fff326;
        margin-right: 8px;
      }

      @media (max-width: 980px) {
        .site-header {
          padding: 14px 22px;
          flex-wrap: wrap;
        }

        .nav-toggle {
          display: inline-grid;
          place-items: center;
          order: 2;
        }

        .site-header nav {
          order: 4;
          width: 100%;
          display: none;
          flex-direction: column;
          align-items: flex-start;
          gap: 6px;
          padding-top: 10px;
        }

        .site-header nav.open {
          display: flex;
        }

        h1 {
          font-size: 3.3rem;
        }

        h2 {
          font-size: 2.15rem;
        }

        .feature-band,
        .service-stage,
        .why,
        .review-grid,
        .pricing-grid,
        .blog-grid,
        footer,
        .grid-section {
          grid-template-columns: 1fr;
        }

        .feature-band {
          margin-top: -44px;
        }

        .service-grid.right,
        .pricing-grid article.featured {
          margin-top: 0;
          transform: none;
        }

        .reviews {
          background-attachment: scroll;
        }

        .why {
          padding: 32px;
        }
      }

      @media (max-width: 640px) {
        .site-header {
          position: sticky;
        }

        .brand img {
          height: 44px;
        }

        .site-header .pill-button {
          display: none;
        }

        .hero {
          min-height: 560px;
        }

        h1 {
          font-size: 2.45rem;
        }

        h2 {
          font-size: 1.75rem;
        }

        .grid-section {
          gap: 30px;
          padding: 50px 0;
        }

        .reason-grid {
          grid-template-columns: 1fr;
        }

        .copy-stack {
          padding-left: 20px;
        }

        .feature-band article,
        .service-card,
        .review-grid article,
        .pricing-grid article {
          padding: 22px;
        }

        .quote-image figcaption {
          position: static;
          border-left: 0;
          border-top: 4px solid #fff326;
        }

        footer {
          padding: 44px 22px;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .wow {
          animation: none !important;
          visibility: visible !important;
        }
        .hero-bg {
          animation: none;
        }
      }
    </style>
  </body>
</html>
